@page "/play"
@using arcadeServer
@attribute [StreamRendering]
@inject GameData GameData;
@rendermode InteractiveServer
<PageTitle>Play</PageTitle>

<h1>Play</h1>

<h1>Broadcasting</h1>
<p>All Screens Equal</p>

<div>
    <label>
        Text:
        <InputText @bind-Value="BToAllText"/>
    </label>
</div>
<div>
    <button @onclick="BroadcastToAll">Broadcast</button>
</div>


@code {
    [SupplyParameterFromForm] private string BToAllText { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {

    }

    private void BroadcastToAll()
    {
        foreach (var a in GameData.Screens)
        {
            a.SendText(BToAllText);
        }
    }

}